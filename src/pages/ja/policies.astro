---
import Layout from '../../layouts/Layout.astro';
import { siteJa } from '../../data/site.ja';
import { policiesJa } from '../../data/policies.ja';
import { uiJa } from '../../data/ui.ja';

const ui = uiJa;
const policies = policiesJa;
---

<Layout
  locale="ja"
  title={`${policies.pageTitle} — ${siteJa.meta.title}`}
  description={siteJa.meta.description}
  ui={ui}
>
  <section class="hero">
    <div class="container">
      <h1>{policies.pageTitle}</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {policies.sections.map((section) => (
        <div class="policy-section">
          <h2>{section.heading}</h2>
          {section.paragraphs?.map((p) => <p>{p}</p>)}
          {section.list && (
            <ul class="bullet-list">
              {section.list.map((item) => <li>{item}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .policy-section {
    margin-bottom: 2rem;
  }
</style>
