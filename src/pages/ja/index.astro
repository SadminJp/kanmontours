---
import Layout from '../../layouts/Layout.astro';
import TourCard from '../../components/TourCard.astro';
import { siteJa } from '../../data/site.ja';
import { toursJa } from '../../data/tours.ja';
import { uiJa } from '../../data/ui.ja';

const site = siteJa;
const tours = toursJa;
const ui = uiJa;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout locale="ja" title={site.meta.title} description={site.meta.description} ui={ui}>
  <section class="hero" style={`--hero-bg-image: url(${base}/images/hero.jpg)`}>
    <div class="container">
      <div class="hero__rule"></div>
      <span class="eyebrow">{site.hero.eyebrow}</span>
      <h1>{site.hero.title}</h1>
      <p class="tagline">{site.hero.tagline}</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href={`${base}/ja/booking/`}>{ui.nav.booking}</a>
        <a class="btn btn--ghost" href={`${base}/ja/#tours`}>{ui.nav.tours}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{site.intro.heading}</h2>
      <div class="with-image">
        <div>
          {site.intro.paragraphs.map((p) => <p>{p}</p>)}
        </div>
        <div class="intro-media">
          <figure class="intro-media__scenic">
            <img src={`${base}/images/site/kanmon-bridge-sunset.jpg`} alt="夕暮れの関門橋と関門海峡" loading="lazy" />
          </figure>
          <div class="with-image__img with-image__img--portrait">
            <img src={`${base}/images/site/kyushu-map.jpg`} alt="関門海峡周辺の北九州市と下関市を示す九州・本州の地図" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about-cities" class="section section--alt">
    <div class="container">
      <h2>{site.cities.heading}</h2>

      <div class="city-section">
        <h3>{site.cities.kitakyushu.title}</h3>
        {site.cities.kitakyushu.paragraphs.map((p) => <p>{p}</p>)}
        <div class="grid grid--3 city-gallery">
          <img src={`${base}/images/site/kitakyushu-bridge.jpg`} alt="若戸大橋と関門海峡(北九州市)" loading="lazy" />
          <img src={`${base}/images/site/kitakyushu-castle-area.jpg`} alt="小倉城とリバーウォーク北九州" loading="lazy" />
          <img src={`${base}/images/site/mojiko-station.jpg`} alt="門司港レトロ駅舎(北九州市)" loading="lazy" />
        </div>
      </div>

      <div class="city-section">
        <h3>{site.cities.shimonoseki.title}</h3>
        {site.cities.shimonoseki.paragraphs.map((p) => <p>{p}</p>)}
        <div class="grid grid--3 city-gallery">
          <img src={`${base}/images/site/shimonoseki-strait.jpg`} alt="関門海峡と関門橋(下関市)" loading="lazy" />
          <img src={`${base}/images/site/shimonoseki-tower.jpg`} alt="赤間神宮(下関市)" loading="lazy" />
          <img src={`${base}/images/site/shimonoseki-fugu.jpg`} alt="ふくの像(下関市)" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="offer" class="section">
    <div class="container">
      <h2>{site.offer.heading}</h2>
      <div class="with-image">
        <div>
          {site.offer.paragraphs.map((p) => <p>{p}</p>)}
          <h3>{site.offer.specialHeading}</h3>
          <ul class="bullet-list">
            {site.offer.specialPoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>
        <div class="with-image__img img-stack">
          <img src={`${base}/images/site/retro-street.jpg`} alt="ツアーで巡る趣のある裏通り" loading="lazy" />
          <img src={`${base}/images/site/cafe-break.jpg`} alt="ツアー途中のカフェでのひと休み" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="tours" class="section section--alt">
    <div class="container">
      <h2>{site.tours.heading}</h2>
      <p>{site.tours.intro}</p>
      <div class="grid grid--4">
        {tours.map((tour) => <TourCard locale="ja" tour={tour} ui={ui} />)}
      </div>
    </div>
  </section>

  <section id="about-us" class="section">
    <div class="container">
      <h2>{site.about.heading}</h2>
      <div class="with-image">
        <div>
          {site.about.paragraphs.map((p) => <p>{p}</p>)}
        </div>
        <div class="with-image__img img-duo">
          <img src={`${base}/images/site/guide-orange-folder.jpg`} alt="オレンジ色の小物を持つ関門ツアーのガイド" loading="lazy" />
          <img src={`${base}/images/site/guide-orange-cap.jpg`} alt="関門ツアーのガイドが身につけるオレンジ色の帽子" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="access" class="section section--alt">
    <div class="container">
      <h2>{site.access.heading}</h2>
      <div class="access-map">
        <img src={`${base}/images/site/shinkansen-map.jpg`} alt="山陽新幹線 路線図" loading="lazy" />
      </div>
      <div class="grid grid--2">
        {site.access.groups.map((group) => (
          <div>
            <h3>{group.heading}</h3>
            {group.routes.map((route) => (
              <div>
                <strong>{route.label}</strong>
                {route.lines.map((line) => <p>{line}</p>)}
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
