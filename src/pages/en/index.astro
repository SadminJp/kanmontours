---
import Layout from '../../layouts/Layout.astro';
import TourCard from '../../components/TourCard.astro';
import { siteEn } from '../../data/site.en';
import { toursEn } from '../../data/tours.en';
import { uiEn } from '../../data/ui.en';

const site = siteEn;
const tours = toursEn;
const ui = uiEn;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout locale="en" title={site.meta.title} description={site.meta.description} ui={ui}>
  <section class="hero" style={`--hero-bg-image: url(${base}/images/hero.jpg)`}>
    <div class="container">
      <div class="hero__rule"></div>
      <span class="eyebrow">{site.hero.eyebrow}</span>
      <h1>Kanmon Strait Walking Tours</h1>
      <div class="hero__cta">
        <a class="btn btn--primary" href={`${base}/en/booking/`}>{ui.nav.booking}</a>
        <a class="btn btn--ghost" href={`${base}/en/#tours`}>{ui.nav.tours}</a>
      </div>
    </div>
  </section>

  <section class="city-banner">
    <div class="container">
      <h2>{site.hero.title}</h2>
      <p class="city-banner__tagline">{site.hero.tagline}</p>
    </div>
    <figure class="city-banner__image">
      <img src={`${base}/images/site/kanmon-bridge-sunset.jpg`} alt="The Kanmon Bridge glowing at sunset over the strait" loading="lazy" />
    </figure>
  </section>

  <section class="section">
    <div class="container">
      <h2>{site.intro.heading}</h2>
      <div class="with-image">
        <div>
          {site.intro.paragraphs.map((p) => <p>{p}</p>)}
        </div>
        <div class="with-image__img with-image__img--portrait">
          <img src={`${base}/images/site/kyushu-map.jpg`} alt="Map of Kyushu and Honshu showing Kitakyushu and Shimonoseki at the Kanmon Strait" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="about-cities" class="section section--alt">
    <div class="container">
      <h2>{site.cities.heading}</h2>

      <div class="city-section">
        <h3>{site.cities.kitakyushu.title}</h3>
        {site.cities.kitakyushu.paragraphs.map((p) => <p>{p}</p>)}
        <div class="grid grid--3 city-gallery">
          <img src={`${base}/images/site/kitakyushu-bridge.jpg`} alt="Wakato Bridge over the Kanmon Strait, Kitakyushu" loading="lazy" />
          <img src={`${base}/images/site/kitakyushu-castle-area.jpg`} alt="Kokura Castle and Riverwalk Kitakyushu" loading="lazy" />
          <img src={`${base}/images/site/mojiko-station.jpg`} alt="Mojiko Retro Station, Kitakyushu" loading="lazy" />
        </div>
      </div>

      <div class="city-section">
        <h3>{site.cities.shimonoseki.title}</h3>
        {site.cities.shimonoseki.paragraphs.map((p) => <p>{p}</p>)}
        <div class="grid grid--3 city-gallery">
          <img src={`${base}/images/site/shimonoseki-strait.jpg`} alt="Aerial view of the Kanmon Strait and Kanmon Bridge, Shimonoseki" loading="lazy" />
          <img src={`${base}/images/site/shimonoseki-tower.jpg`} alt="Akama Jingu Shrine, Shimonoseki" loading="lazy" />
          <img src={`${base}/images/site/shimonoseki-fugu.jpg`} alt="Fugu (blowfish) statue, Shimonoseki" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="offer" class="section">
    <div class="container">
      <h2>{site.offer.heading}</h2>
      <div class="with-image">
        <div>
          {site.offer.paragraphs.map((p) => <p>{p}</p>)}
          <h3>{site.offer.specialHeading}</h3>
          <ul class="bullet-list">
            {site.offer.specialPoints.map((point) => <li>{point}</li>)}
          </ul>
        </div>
        <div class="with-image__img img-stack">
          <img src={`${base}/images/site/retro-street.jpg`} alt="A quiet retro backstreet explored on a walking tour" loading="lazy" />
          <img src={`${base}/images/site/cafe-break.jpg`} alt="A relaxing cafe break during a tour" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="tours" class="section section--alt">
    <div class="container">
      <h2>{site.tours.heading}</h2>
      <p>{site.tours.intro}</p>
      <div class="grid grid--4">
        {tours.map((tour) => <TourCard locale="en" tour={tour} ui={ui} />)}
      </div>
    </div>
  </section>

  <section id="about-us" class="section">
    <div class="container">
      <h2>{site.about.heading}</h2>
      <div class="with-image">
        <div>
          {site.about.paragraphs.map((p) => <p>{p}</p>)}
        </div>
        <div class="with-image__img img-duo">
          <img src={`${base}/images/site/guide-orange-folder.jpg`} alt="A Kanmon Tours guide holding something orange" loading="lazy" />
          <img src={`${base}/images/site/guide-orange-cap.jpg`} alt="An orange cap worn by Kanmon Tours guides" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="access" class="section section--alt">
    <div class="container">
      <h2>{site.access.heading}</h2>
      <div class="access-map">
        <img src={`${base}/images/site/shinkansen-map.jpg`} alt="Sanyo Shinkansen route map" loading="lazy" />
      </div>
      <div class="grid grid--2">
        {site.access.groups.map((group) => (
          <div>
            <h3>{group.heading}</h3>
            {group.routes.map((route) => (
              <div>
                <strong>{route.label}</strong>
                {route.lines.map((line) => <p>{line}</p>)}
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
